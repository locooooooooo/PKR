{
  "name": "pkr-runtime",
  "version": "0.7.0-alpha.1",
  "description": "Open project Runtime for governed AI-native software development.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/locooooooooo/PKR.git"
  },
  "homepage": "https://github.com/locooooooooo/PKR#readme",
  "bugs": {
    "url": "https://github.com/locooooooooo/PKR/issues"
  },
  "keywords": [
    "ai-agent",
    "agent-harness",
    "codex",
    "codex-cli",
    "governance",
    "local-first",
    "runtime",
    "sqlite",
    "verification"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "pkr": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "schemas/",
    "VERSION"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:v0.4": "node scripts/generate-v04-artifacts.mjs",
    "check:boundaries": "node scripts/check-runtime-boundaries.mjs",
    "build": "npm run check:boundaries && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/cli-safety.test.js dist/runtime.test.js dist/orchestration.test.js dist/v07.test.js dist/release.test.js",
    "verify:schemas": "node scripts/run-conformance.mjs",
    "verify": "npm run generate:v0.4 && npm run verify:schemas && npm test",
    "check:package": "node scripts/check-package.mjs",
    "prepack": "npm run build && npm run check:package",
    "prepublishOnly": "npm run verify"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0"
  }
}
