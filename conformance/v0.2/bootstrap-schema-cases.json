          "principalId": "human_001"
        },
        "project": {
          "projectId": "project_001",
          "name": "pkr",
          "title": "Project Kernel Runtime",
          "description": "An open runtime specification for AI-native projects."
        },
        "seeds": {
          "mission": {
            "id": "mission_001",
            "name": "pkr-mission",
            "title": "Define and prove PKR",
            "spec": {
              "outcome": "Deliver a usable PKR specification and reference runtime.",
