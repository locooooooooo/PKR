                "mode": "none",
                "reason": "A release deadline is not committed during bootstrap."
              },
              "owners": [
                {
                  "principalType": "human",
                  "principalId": "human_001",
                  "accountability": "accountable"
                }
              ]
            }
          },
          "ownerRole": {
            "id": "role_001",
